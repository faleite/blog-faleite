    <item>
      <title>Comandos Git</title>
      <link>http://localhost:1313/blog/comandos-git/</link>
      <pubDate>Wed, 24 Jun 2026 11:47:10 +0100</pubDate>
      
      <guid>http://localhost:1313/blog/comandos-git/</guid>
      <description>
        
        
        &lt;h1&gt;Git&lt;/h1&gt;&lt;p&gt;&lt;em&gt;&amp;ldquo;É um consenso que a verdade está em um lugar, e geralmente está longe.&amp;rdquo;&lt;/em&gt;&lt;/p&gt;
&lt;h3&gt;Principais Ações&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;principais-ações&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#principais-a%c3%a7%c3%b5es&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Ação&lt;/th&gt;
					&lt;th&gt;Comando&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;Transformar uma pasta em pasta git&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git init&lt;/strong&gt; (cria pasta &lt;strong&gt;.git&lt;/strong&gt; na pasta atual)&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Saber onde você esta no git&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git status&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Preparar arquivo a ser enviado a um commit&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git add &amp;lt;arquivo&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Desfazer preparação de arquivo a ser commitado&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git rm &amp;ndash;cached &amp;lt;arquivo&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Fazer registro do arquivo (commit)&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git commit -m &amp;lsquo;Menssagem sobre o arquivo!&amp;rsquo;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Ver todas as alterações feitas no git&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git log&lt;/strong&gt; (digite &lt;strong&gt;q&lt;/strong&gt; para sair do git log)&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Ver diferenças entre as versões dos arquivos&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git diff&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Mostrar difença entre uma branch e outra&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git diff main origin/main&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Preparar todos os arquivos para um commit&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git add .&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Guardar todos arquivos trackeados pelo git&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git add -u&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;hr&gt;
&lt;h3&gt;Branch e Checkout&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;branch-e-checkout&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#branch-e-checkout&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Ação&lt;/th&gt;
					&lt;th&gt;Comando&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;Mostrar branches existentes locais&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git branch&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Mostrar branches existentes locais e remotas&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git branch -a&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Criar uma nova branch&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git branch &amp;lt;nome&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Cria uma nova branch e muda para a branch criada&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git checkout -b &amp;lt;nomeBranch&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Mudar de branch&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git checkout &amp;lt;nomeBranch&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Ir para um commit específico&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git checkout &amp;lt;numeroCommit&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Apagar uma branch&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git branch -d &amp;lt;nomeBranch&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Reverte o arquivo para o ultimo commit&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git checkout -- &amp;lt;nomeArquivo&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Desfazer preparação de arquivos modificados para o próximo commit&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git reset HEAD &amp;lt;nomeArquivo&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;h3&gt;Mais sobre Branch&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;mais-sobre-branch&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#mais-sobre-branch&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Ação&lt;/th&gt;
					&lt;th&gt;Comando&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;Renomear branch local&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git branch -m &amp;lt;novoNome&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Renomear uma branch enquanto esta em outra&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git branch -m &amp;lt;nomeAntigo&amp;gt; &amp;lt;novoNome&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Renomear branch default global&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git config &amp;ndash;global init.defaultBranch &amp;lt;novo-nome&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Mostrar nome e ultimo commit da branch local&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git branch -v&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Mostrar nome e ultimo commit da branch remota&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git branch -vv&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;hr&gt;
&lt;h3&gt;Merge e Rebase&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;merge-e-rebase&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#merge-e-rebase&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;&lt;ul&gt;
&lt;li&gt;Estas duas ferramentas permitem atualizar seu branch local a partir de&lt;br&gt;
outro branch&lt;/li&gt;
&lt;li&gt;Produzem quase o mesmo resultado final&lt;/li&gt;
&lt;li&gt;O git merge cria uma nova ramificação que contém as alterações de todas&lt;br&gt;
as ramificações combinadas&lt;/li&gt;
&lt;li&gt;O git rebase pega todas as alterações de uma ramificação e aplica as mudanças&lt;br&gt;
diretamente na outra ramificação, como se o trabalho tivesse sido feito em&lt;br&gt;
sequência, em uma única ramificação.&lt;/li&gt;
&lt;/ul&gt;
&lt;h4&gt;Rebase&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;rebase&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#rebase&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h4&gt;&lt;ul&gt;
&lt;li&gt;Serve para quando você quer colocar outro branch sob seu branch, sobrepor todos os commits&lt;br&gt;
e resolver tudo o que acontecer.&lt;/li&gt;
&lt;li&gt;Rebase acha o ponto comum e pega todos os commits a partir dele, separa eles e&lt;br&gt;
volta ao branch principal e aplica todos os commits por cima.&lt;/li&gt;
&lt;/ul&gt;
&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Ação&lt;/th&gt;
					&lt;th&gt;Comando&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;Faça o rebase do main no meu branch&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git rebase &amp;lt;main&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Emcorporar modificação de uma outra branch na branch master&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git merge &amp;lt;nomeBranch&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Continuar o rebase (Após alterar/corrigir arquivo/conflito)&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git rebase &amp;ndash;continue&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Alterar o commit (mensagem do commit)&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git commit &amp;ndash;amend&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Caso não funcione git commit &amp;ndash;amend&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git commit &amp;ndash;amend -m &amp;ldquo;mensagem&amp;rdquo;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Alterar arquivo do ultimo commit sem alterar mensagem no git&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git commit &amp;ndash;amend &amp;ndash;no-edit&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;h4&gt;Mais comandos&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;mais-comandos&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#mais-comandos&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h4&gt;&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Ação&lt;/th&gt;
					&lt;th&gt;Comando&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;Editar em sequência vários commits&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git rebase -i HEAD~4&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Observações / Etapas&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;em&gt;HEAD~4 = edita os 4 ultimos comites&lt;/em&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;em&gt;Para editar os commits substitua a palavra &amp;lsquo;pick&amp;rsquo; por &amp;rsquo;edit&amp;rsquo;&lt;/em&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;em&gt;Repita os dois ultimos passos até concluir o rebase.&lt;/em&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Ação&lt;/th&gt;
					&lt;th&gt;Comando&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;Comprimir vários commits em um unico commit&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git rebase -i HEAD~4&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Observações / Etapas&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;&lt;strong&gt;-i HEAD~4&lt;/strong&gt; faz o squash nos 4 ultimos commits&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Para juntar os commits ao commit anterior substitua a palavra &amp;lsquo;pick&amp;rsquo; por &amp;lsquo;squash&amp;rsquo;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Alterar o commit: &lt;strong&gt;git commit &amp;ndash;amend&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Continuar o rebase para fazer o squash: &lt;strong&gt;git rebase &amp;ndash;continue&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;hr&gt;
&lt;h4&gt;Merge&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;merge&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#merge&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h4&gt;&lt;ul&gt;
&lt;li&gt;Quando quero pegar um branch, todos os seus commits e suas diferenças e fazer&lt;br&gt;
um commit de merge (uma fundição), que vai colocar todos esses commits no meu&lt;br&gt;
branch. Em vez de colocar abaixo, coloca acima.&lt;/li&gt;
&lt;/ul&gt;
&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Ação&lt;/th&gt;
					&lt;th&gt;Comando&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;Fazer merge da branch principal com a sua branch&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git merge &amp;lt;suaBranch&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Observações&lt;/th&gt;
					&lt;th&gt;Etapas&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;Ir para a branch principal&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git checkout &amp;lt;main&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Fazer o merge&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git merge &amp;lt;suaBranch&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Voltar para a sua branch&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git checkout &amp;lt;suaBranch&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Traser a branch origin/main para a branch main&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git merge origin/main&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;hr&gt;
&lt;h3&gt;Stash&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;stash&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#stash&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;&lt;ul&gt;
&lt;li&gt;É uma ferramenta que permite guardar rapidamente as modificações e trazê-las&lt;br&gt;
de volta.&lt;/li&gt;
&lt;li&gt;Permite deixar de lado modificações feitas, quando você precisa urgentemente&lt;br&gt;
fazer outra coisa.&lt;/li&gt;
&lt;li&gt;É como se você criasse pequenas branches.&lt;/li&gt;
&lt;li&gt;Permite limpar rapidamente o git para poder fazer uma operação nele&lt;br&gt;
e voltar.&lt;/li&gt;
&lt;li&gt;Git stash pega tudo que foi modificado na pasta, cria um pequeno commit&lt;br&gt;
e guarda&lt;/li&gt;
&lt;li&gt;Não é um commit verdadeiro, tem como vantagem ir rapidamente de um lado&lt;br&gt;
para o outro.&lt;/li&gt;
&lt;/ul&gt;
&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Ação&lt;/th&gt;
					&lt;th&gt;Comando&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;Criar um stash&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git stash&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Ver o que há no stash&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git stash list&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Reaplicar commit stash&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git stash pop&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;hr&gt;
&lt;h3&gt;Uso remoto do git&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;uso-remoto-do-git&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#uso-remoto-do-git&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;&lt;ul&gt;
&lt;li&gt;Enviar projeto para repositório no github via SSH&lt;/li&gt;
&lt;/ul&gt;
&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Ação&lt;/th&gt;
					&lt;th&gt;Comando&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;Conectar diretório ao repositório&lt;/td&gt;
					&lt;td&gt;&lt;code&gt;git remote add origin \&amp;lt;endereçoSshGit&amp;gt;&lt;/code&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Nomear branch do repositótio&lt;/td&gt;
					&lt;td&gt;&lt;code&gt;git branch -M main&lt;/code&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Envia e conecta a branch local a branch remoto&lt;/td&gt;
					&lt;td&gt;&lt;code&gt;git push -u origin &amp;lt;nome-da-branch&amp;gt;&lt;/code&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Clonar repositório remoto&lt;/td&gt;
					&lt;td&gt;&lt;code&gt;git clone \&amp;lt;endereçoSshGit&amp;gt;&lt;/code&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Trazer/recuperar informações remotas de vários branches&lt;/td&gt;
					&lt;td&gt;&lt;code&gt;git fetch&lt;/code&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Trazer/recuperar informações remotas de todos as branches&lt;/td&gt;
					&lt;td&gt;&lt;code&gt;git fetch --all&lt;/code&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Atualizar informações na branch main trazidas pelo &lt;code&gt;fetch&lt;/code&gt;&lt;/td&gt;
					&lt;td&gt;&lt;code&gt;git rebase origin/main&lt;/code&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Fazer &lt;code&gt;fetch&lt;/code&gt; e &lt;code&gt;rebase&lt;/code&gt; ao mesmo tempo&lt;/td&gt;
					&lt;td&gt;&lt;code&gt;git pull --rebase&lt;/code&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Fazer &lt;code&gt;fetch&lt;/code&gt; e &lt;code&gt;merge&lt;/code&gt; ao mesmo tempo&lt;/td&gt;
					&lt;td&gt;&lt;code&gt;git pull&lt;/code&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Fazer &lt;code&gt;fetch&lt;/code&gt; e &lt;code&gt;merge&lt;/code&gt; em branch especifica&lt;/td&gt;
					&lt;td&gt;&lt;code&gt;git pull origin \&amp;lt;nome-branch&amp;gt;&lt;/code&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Fazer &lt;code&gt;fetch&lt;/code&gt; em branch especifica&lt;/td&gt;
					&lt;td&gt;&lt;code&gt;git fetch origin \&amp;lt;nome-branch&amp;gt;&lt;/code&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;hr&gt;
&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Observações&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;Endereço ssh é parecido com: &lt;em&gt;&lt;a
    href=&#34;mailto:git@github.com&#34;&gt;git@github.com&lt;/a&gt;:faleite/tutors.git&lt;/em&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;h4&gt;Mais comandos&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;mais-comandos-1&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#mais-comandos-1&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h4&gt;&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Ação&lt;/th&gt;
					&lt;th&gt;Comando&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;Mostrar nome do repositótio remoto&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git remote&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Mostrar caminho do repositótio remoto&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git remote -v&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Fazer &lt;strong&gt;fetch&lt;/strong&gt; e &lt;strong&gt;rebase&lt;/strong&gt; ao mesmo tempo&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git pull &amp;ndash;rebase &amp;ndash;origin main&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Mostrar commits remoto&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git log origin/main&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Criar arquivo no repositório&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;touch &amp;lt;nomeArquivo&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Criar uma linha de texto no arquivo&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;echo &amp;ldquo;linha de text&amp;rdquo; &amp;raquo; &amp;lt;nomeArquivo&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Mostrar conteúdo do arquivo&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;cat &amp;lt;nomeArquivo&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Enviar commit para o github&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git push&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;hr&gt;
&lt;h2&gt;Mais comandos do Git&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;mais-comandos-do-git&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#mais-comandos-do-git&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h2&gt;&lt;h3&gt;Git Log&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;git-log&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#git-log&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Ação&lt;/th&gt;
					&lt;th&gt;Comando&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;Ver cada uma das alterações que ja foram feitas&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git log -p&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Ver duas ultimas alterações&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git log -p -2&lt;/strong&gt; (-2 ou -1 &amp;hellip;etc)&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Ver quais arquivos foram alterados&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git log &amp;ndash;stat&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Ver ultima inclusão e o que foi alterado&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git log -1 &amp;ndash;stat&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Ver a alteração do ultimo commit&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git log -p -1&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Monitorar arquivo específico&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git log &amp;ndash; &amp;lt;nomeArquvio&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Mostrar gráfico das alterações&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git log &amp;ndash;graph&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Mostrar gráfico das alterações em apenas uma linha&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git log &amp;ndash;graph &amp;ndash;oneline&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Mostrar cada commit em apenas uma linha&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git log &amp;ndash;oneline&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Mostrar cada commit em apenas uma linha de forma resumida&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git log &amp;ndash;pretty=oneline&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Mostrar os commits por autor&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git log &amp;ndash;author=&amp;ldquo;Fabricio Araujo&amp;rdquo;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Buscar commits por palavras&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git log &amp;ndash;grep=&amp;ldquo;Olá&amp;rdquo;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;h3&gt;Git log detalhado&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;git-log-detalhado&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#git-log-detalhado&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;flag&lt;/th&gt;
					&lt;th&gt;Ação&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;%h&lt;/td&gt;
					&lt;td&gt;Abreviação do hash&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;%an&lt;/td&gt;
					&lt;td&gt;Nome do autor&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;%ar&lt;/td&gt;
					&lt;td&gt;Data&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;%s&lt;/td&gt;
					&lt;td&gt;Comentário&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;ul&gt;
&lt;li&gt;Exemplo de histórico com formatação específica&lt;/li&gt;
&lt;/ul&gt;
&lt;div class=&#34;hextra-code-block hx:relative hx:mt-6 hx:first:mt-0 hx:group/code&#34;&gt;

&lt;div&gt;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;&#34;&gt;&lt;code class=&#34;language-bash&#34; data-lang=&#34;bash&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;&lt;span style=&#34;color:#75715e&#34;&gt;# hash abreviada, autor, data e comentário&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;git log --pretty&lt;span style=&#34;color:#f92672&#34;&gt;=&lt;/span&gt;format:&lt;span style=&#34;color:#e6db74&#34;&gt;&amp;#34;%h - %an, %ar : %s&amp;#34;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&#34;hextra-code-copy-btn-container hx:opacity-0 hx:transition hx:group-hover/code:opacity-100 hx:flex hx:gap-1 hx:absolute hx:m-[11px] hx:right-0 hx:top-0&#34;&gt;
  &lt;button
