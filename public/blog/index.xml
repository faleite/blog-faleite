&lt;h3&gt;Git Config&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;git-config&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#git-config&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Ação&lt;/th&gt;
					&lt;th&gt;Comando&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;Listar as variáveis de configuração do git&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git config -l&lt;/strong&gt; / &lt;strong&gt;git config &amp;ndash;list&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Listar as variáveis local do git&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git config -l &amp;ndash;local&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Listar as variáveis global do git&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git config -l &amp;ndash;global&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Configurar user name&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git config user.name &amp;lt;nomeUsuario&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Configurar user email&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git config user.email &lt;a
    href=&#34;mailto:teste@gmail.com&#34;&gt;teste@gmail.com&lt;/a&gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Criar atalhos com alias do git&lt;/td&gt;
					&lt;td&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;alias.conf -&amp;gt; conf = nome do atalho&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git config &amp;ndash;local alias.conf &amp;lsquo;config &amp;ndash;local -l&amp;rsquo;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Deletar atalho feito no git&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git config &amp;ndash;unset alias.conf&lt;/strong&gt; (alias.conf -&amp;gt; nome atalho)&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;ul&gt;
&lt;li&gt;Adicionar co-autor no commit&lt;/li&gt;
&lt;/ul&gt;
&lt;div class=&#34;hextra-code-block hx:relative hx:mt-6 hx:first:mt-0 hx:group/code&#34;&gt;

&lt;div&gt;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;&#34;&gt;&lt;code class=&#34;language-bash&#34; data-lang=&#34;bash&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;git commit -m &lt;span style=&#34;color:#e6db74&#34;&gt;&amp;#39;Menssagem sobre o arquivo!
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;&lt;span style=&#34;color:#e6db74&#34;&gt;&amp;gt;
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;&lt;span style=&#34;color:#e6db74&#34;&gt;&amp;gt; Co-authored-by: nome &amp;lt;email.@email.com&amp;gt;&amp;#39;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&#34;hextra-code-copy-btn-container hx:opacity-0 hx:transition hx:group-hover/code:opacity-100 hx:flex hx:gap-1 hx:absolute hx:m-[11px] hx:right-0 hx:top-0&#34;&gt;
  &lt;button
    class=&#34;hextra-code-copy-btn hx:group/copybtn hx:cursor-pointer hx:transition-all hx:active:opacity-50 hx:bg-primary-700/5 hx:border hx:border-black/5 hx:text-gray-600 hx:hover:text-gray-900 hx:rounded-md hx:p-1.5 hx:dark:bg-primary-300/10 hx:dark:border-white/10 hx:dark:text-gray-400 hx:dark:hover:text-gray-50&#34;
    title=&#34;Copy code&#34;
    aria-label=&#34;Copy code&#34;
    data-copied-label=&#34;Copied!&#34;
  &gt;
    &lt;div class=&#34;hextra-copy-icon hx:group-[.copied]/copybtn:hidden hx:pointer-events-none hx:h-4 hx:w-4&#34;&gt;&lt;/div&gt;
&lt;div class=&#34;hextra-success-icon hx:hidden hx:group-[.copied]/copybtn:block hx:pointer-events-none hx:h-4 hx:w-4&#34;&gt;&lt;/div&gt;
  &lt;/button&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;hr&gt;
&lt;h3&gt;Os três estágios do git&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;os-três-estágios-do-git&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#os-tr%c3%aas-est%c3%a1gios-do-git&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Estágio&lt;/th&gt;
					&lt;th&gt;Estado&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;WORKING TREE (DIRECTORY)&lt;/td&gt;
					&lt;td&gt;O arquivo esta apenas no diretório&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;STAGING AREA&lt;/td&gt;
					&lt;td&gt;O arquivo está numa area intermediária do git (quando passamos o &lt;strong&gt;git add&lt;/strong&gt;)&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;.GIT DIRECTORY (REPOSITORY)&lt;/td&gt;
					&lt;td&gt;O arquivo esta no git (quando fazemos o &lt;strong&gt;commit&lt;/strong&gt;)&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;hr&gt;
&lt;h3&gt;Tags de commit no git&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;tags-de-commit-no-git&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#tags-de-commit-no-git&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Ação&lt;/th&gt;
					&lt;th&gt;Comando&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;Criar uma tag&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git tag -a v1.0 -m &amp;lt;nomeVersao&amp;gt;&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;v1.0&lt;/td&gt;
					&lt;td&gt;é o nome da Tag&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;&amp;lt;nomeVersao&amp;gt;&lt;/td&gt;
					&lt;td&gt;é mensagem da tag&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Listar todas as tags criadas&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git tag&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Listar todas as tags criadas e suas mensagens&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git tag -n&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Mostrar o conteúdo das tegs&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git show &amp;ndash;tags&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Apagar tags&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git tag -d v1.0&lt;/strong&gt; (v1.0 = nome da tag)&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Enviar &lt;strong&gt;tag&lt;/strong&gt; criada para o repositório remoto&lt;/td&gt;
					&lt;td&gt;&lt;code&gt;git push origin &amp;lt;nome-da-tag&amp;gt;&lt;/code&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;
&lt;hr&gt;
&lt;h3&gt;Menssagem padronizada do comiit no git:&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;menssagem-padronizada-do-comiit-no-git&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#menssagem-padronizada-do-comiit-no-git&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Ação&lt;/th&gt;
					&lt;th&gt;Comando&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;Cria arquivo com o nome&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;.git message&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Edite uma menssagem padrão neste arquivo&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;.git message&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Configurar o template da menssagem no git&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git config commit.tamplate .gitmessage&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Listar a variáveis que foram configuradas no git&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git config &amp;ndash;list&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
					&lt;td&gt;Fazer commit com menssagem padronisada&lt;/td&gt;
					&lt;td&gt;&lt;strong&gt;git commit&lt;/strong&gt;&lt;/td&gt;
			&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;

      </description>
    </item>
    
